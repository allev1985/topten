# myfaves Environment Configuration
# Copy this file to .env.local and fill in the values

# Auth (required)
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# Application URL (required)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database Connection (required)
# Default for local Docker development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/topten

# Email (required for auth flows)
# Local dev: uses Mailhog (pnpm dev:email to start, UI at http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@myfaves.local

# Google Places API (required for place search)
# Generate a key at https://console.cloud.google.com/ with Places API (New) enabled.
# IMPORTANT: never expose this key on the client — no NEXT_PUBLIC_ prefix.
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# Redis (optional — defaults to local Docker instance)
# Connection string for the Redis cache/rate-limit backend
REDIS_URL=redis://localhost:6379
# TTL in seconds for cached session data (default: 60)
SESSION_CACHE_TTL_SECONDS=60

# Logging (optional)
# One of: trace | debug | info | warn | error | fatal
# Defaults to "debug" in development, "info" in production
LOG_LEVEL=debug

# OpenTelemetry (optional)
# Service name shown in Grafana traces and metrics
OTEL_SERVICE_NAME=topten
# OTLP collector endpoint — defaults to http://localhost:4318 (local Grafana stack)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
