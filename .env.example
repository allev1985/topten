# YourFavs Environment Configuration
# Copy this file to .env.local and fill in the values

# Supabase Configuration (required)
# Get these values from `pnpm supabase:start` output
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Connection (required)
# Default for local Supabase development
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Google Places API (required)
# All place searches use the Google Places (New) API.
# Generate a key at https://console.cloud.google.com/ with Places API (New) enabled.
# IMPORTANT: never expose this key on the client — use server-side only (no NEXT_PUBLIC_ prefix).
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# Logging (optional)
# One of: trace | debug | info | warn | error | fatal
# Defaults to "debug" in development, "info" in production
LOG_LEVEL=debug

# OpenTelemetry (optional)
# Service name shown in Grafana traces and metrics
OTEL_SERVICE_NAME=topten
# OTLP collector endpoint — defaults to http://localhost:4318 (local Grafana stack)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
