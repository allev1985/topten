{
  "title": "myfaves — Overview",
  "uid": "topten-overview",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["topten"],
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (spans/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(traces_spanmetrics_calls_total{service=\"topten\"}[1m])",
          "legendFormat": "{{span_name}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(traces_spanmetrics_calls_total{service=\"topten\",status_code=\"STATUS_CODE_ERROR\"}[1m])",
          "legendFormat": "{{span_name}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "P99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(traces_spanmetrics_duration_milliseconds_bucket{service=\"topten\"}[1m]))",
          "legendFormat": "p99 {{span_name}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Log Volume by Level",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (level) (rate({service=\"topten\"}[1m]))",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Recent Errors",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "showLabels": false, "wrapLogMessage": true },
      "targets": [
        {
          "expr": "{service=\"topten\"} | json | level =~ \"error|fatal\""
        }
      ]
    }
  ]
}
